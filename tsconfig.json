{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "declaration": false,
    "inlineSources": true,
    "inlineSourceMap": true,
    "importHelpers": true,
    "experimentalDecorators": false,
    "useDefineForClassFields": true,
    "emitDecoratorMetadata": false,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"]
}
