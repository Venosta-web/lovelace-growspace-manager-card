{
  "name": "lovelace-growspace-manager-card",
  "version": "1.1.0-next.9",
  "description": "",
  "main": "rollup.config.js",
  "scripts": {
    "build": "rollup -c && cp dist/growspace-manager-card.js growspace-manager-card.js",
    "copy:ha": "mkdir -p ../../config/www/ && cp dist/growspace-manager-card.js ../../config/www/growspace-manager-card.js",
    "build:dev": "npm run build && npm run copy:ha",
    "watch": "rollup -c -w",
    "build:coverage": "COVERAGE=true rollup -c",
    "test": "vitest run",
    "test:e2e": "npm run build && npm run test:ha",
    "test:ha": "npm --prefix tests/e2e run test",
    "test:ha:headed": "npm --prefix tests/e2e run test:headed",
    "test:ha:debug": "npm --prefix tests/e2e run test:debug",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint 'src/**/*.{ts,js}'",
    "format": "prettier --write 'src/**/*.{ts,js,json,css,md}'"
  },
  "keywords": [],
  "author": "Venosta-web",
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "@ai-hero/sandcastle": "^0.5.11",
    "@lit-labs/rollup-plugin-minify-html-literals": "^0.1.1",
    "@lit-labs/testing": "^0.2.8",
    "@open-wc/testing-helpers": "^3.0.1",
    "@playwright/test": "^1.57.0",
    "@rollup/plugin-commonjs": "^28.0.9",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.10.4",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "@vitest/browser": "^4.1.7",
    "@vitest/browser-playwright": "^4.1.7",
    "@vitest/coverage-istanbul": "^4.1.7",
    "@vitest/coverage-v8": "^4.1.7",
    "c8": "^10.1.3",
    "dotenv": "^17.2.3",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-promise": "^6.6.0",
    "lit": "^3.3.1",
    "playwright": "^1.57.0",
    "prettier": "^3.7.4",
    "rollup": "^4.55.1",
    "rollup-plugin-css-only": "^4.5.5",
    "rollup-plugin-summary": "^3.0.1",
    "semantic-release": "^25.0.3",
    "source-map-support": "^0.5.21",
    "typescript": "^5.9.2",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@lit-labs/virtualizer": "^2.1.1",
    "@lit/context": "^1.1.6",
    "@lit/reactive-element": "^2.1.1",
    "@mdi/js": "^7.4.47",
    "@nanostores/lit": "^0.2.3",
    "@types/three": "^0.182.0",
    "custom-card-helpers": "^1.9.0",
    "luxon": "^3.7.2",
    "nanostores": "^1.1.0",
    "three": "^0.182.0",
    "tslib": "^2.8.1",
    "zod": "^3.25.76"
  }
}
