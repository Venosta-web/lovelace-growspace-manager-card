{
  "name": "lovelace-growspace-manager-card",
  "version": "1.0.30-alpha.1",
  "description": "",
  "main": "rollup.config.js",
  "scripts": {
    "build": "rollup -c && cp dist/growspace-manager-card.js growspace-manager-card.js",
    "build:coverage": "COVERAGE=true rollup -c",
    "test": "playwright test",
    "test:e2e": "npm run build && playwright test --config=playwright.e2e.config.ts",
    "test:e2e:coverage": "playwright test --reporter=html,line && node scripts/coverage-report.cjs",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage:full": "node scripts/run-coverage.cjs",
    "lint": "eslint 'src/**/*.{ts,js}'",
    "format": "prettier --write 'src/**/*.{ts,js,json,css,md}'"
  },
  "keywords": [],
  "author": "Venosta-web",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@rollup/plugin-commonjs": "^28.0.9",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.10.4",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "@vitest/coverage-v8": "4.0.14",
    "c8": "^10.1.3",
    "dotenv": "^17.2.3",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-promise": "^6.6.0",
    "jsdom": "^27.3.0",
    "lit": "^3.3.1",
    "prettier": "^3.7.4",
    "rollup": "^2.79.2",
    "rollup-plugin-css-only": "^4.5.5",
    "source-map-support": "^0.5.21",
    "typescript": "^5.9.2",
    "vitest": "4.0.14"
  },
  "dependencies": {
    "@lit/context": "^1.1.6",
    "@lit/reactive-element": "^2.1.1",
    "@mdi/js": "^7.4.47",
    "custom-card-helpers": "^1.9.0",
    "luxon": "^3.7.2",
    "save-dev": "^0.0.1-security",
    "tslib": "^2.8.1",
    "zod": "^3.24.1"
  }
}
